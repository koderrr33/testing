# =============================================================================
# XENDIT — PAYMENT GATEWAY
# Copy file ini ke .env.local lalu isi value dari Xendit Dashboard.
# Docs: https://docs.xendit.co
# =============================================================================

# "test" = Sandbox (default, aman untuk dev & demo buyer)
# "live" = Production — TODO: Ganti ke Live Key saat production
XENDIT_MODE=test
NEXT_PUBLIC_XENDIT_MODE=test

# -----------------------------------------------------------------------------
# TEST MODE (Sandbox) — pakai key dari Dashboard → Settings → API Keys → Test
# Secret key prefix: xnd_development_
# Public key prefix:  xnd_public_development_
# -----------------------------------------------------------------------------
XENDIT_TEST_SECRET_KEY=xnd_development_REPLACE_ME
XENDIT_TEST_PUBLIC_KEY=xnd_public_development_REPLACE_ME

# Verification token dari Webhook settings (bukan API key)
# Dashboard → Developers → Webhooks → URL → copy Verification Token
XENDIT_TEST_WEBHOOK_TOKEN=REPLACE_ME

# -----------------------------------------------------------------------------
# LIVE MODE (Production) — kosongkan dulu sampai go-live
# Secret key prefix: xnd_production_
# TODO: Ganti ke Live Key saat production
# -----------------------------------------------------------------------------
XENDIT_LIVE_SECRET_KEY=
XENDIT_LIVE_PUBLIC_KEY=
XENDIT_LIVE_WEBHOOK_TOKEN=

# -----------------------------------------------------------------------------
# APP URL — wajib untuk redirect & webhook
# Local: http://localhost:3000
# Production: https://domain-kamu.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# WEBHOOK SETUP (Test Mode)
# =============================================================================
# 1. Jalankan app: npm run dev
# 2. Expose localhost (pilih salah satu):
#    - ngrok http 3000
#    - cloudflared tunnel --url http://localhost:3000
# 3. Xendit Dashboard → Developers → Webhooks → Add URL:
#    https://<tunnel-host>/api/webhook/xendit
# 4. Pilih event: Invoices
# 5. Copy Verification Token → XENDIT_TEST_WEBHOOK_TOKEN
#
# Saat production: buat webhook baru dengan URL production + XENDIT_LIVE_WEBHOOK_TOKEN
# =============================================================================

# =============================================================================
# CARA TEST SETIAP PAYMENT METHOD (Sandbox)
# Semua di halaman hosted checkout Xendit setelah klik "lanjut ke pembayaran".
# Di Test Mode ada tombol simulasi: Simulate Success / Failed / Pending.
# =============================================================================
#
# QRIS
#   → Pilih QRIS → scan/simulate → Simulate Success = PAID
#
# GoPay / OVO / DANA / ShopeePay / LinkAja
#   → Pilih e-wallet → Simulate Success = PAID, Simulate Failed = tetap PENDING
#   → Balik ke situs via failure URL = order CANCELLED
#
# Virtual Account (BCA, BNI, BRI, Mandiri, Permata, BSI, CIMB, Sampoerna)
#   → Pilih bank → dapat nomor VA → Simulate Success = PAID
#   → Jangan bayar sampai expired = EXPIRED (via webhook / refresh status page)
#
# Credit Card
#   → Kartu test: 4000 0000 0000 0002 (success) atau 4000 0000 0000 0001 (failed)
#   → CVV: 123, Exp: bulan/tahun depan
#
# STATUS ORDER DI APP
#   PENDING   → invoice dibuat, belum bayar
#   PAID      → webhook / sync dari Xendit
#   EXPIRED   → invoice kadaluarsa
#   CANCELLED → user batal / gagal bayar / error create invoice
#
# API ALTERNATIF (opsional):
#   POST /api/payment/create  — body JSON, lihat src/schemas/payment.ts
# =============================================================================
